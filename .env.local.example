# =============================================================
# MODELO de variáveis de ambiente do Pauta.
#
# Copie este arquivo para ".env.local" e preencha com os valores reais
# do seu projeto Supabase. O ".env.local" NÃO vai para o git (segredos).
#
# Estes dois valores são PÚBLICOS (vão para o navegador):
#   - a URL é só o endereço do projeto;
#   - a ANON KEY é uma chave pública; quem protege os dados é o RLS.
# Mesmo assim, mantemos o arquivo real fora do git por organização.
#
# No deploy (Vercel), cadastre as mesmas duas variáveis no painel:
#   Project Settings -> Environment Variables.
# =============================================================

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-publica-aqui
