{
  // Configuracao do TypeScript. O TS confere os tipos e pega erros antes de rodar.
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    // O '@/...' vira um atalho para a pasta src — evita ../../../ nos imports.
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  // A pasta supabase/functions roda no Deno (imports "jsr:"), não no Next.
  "exclude": ["node_modules", "supabase"]
}
